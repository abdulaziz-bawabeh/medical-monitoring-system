# ==================================================
# Server
# ==================================================

PORT=5000
HOST=0.0.0.0
NODE_ENV=development

# Local frontend URL.
# Production example:
# FRONTEND_URL=https://your-project.vercel.app
FRONTEND_URL=http://localhost:5173


# ==================================================
# PostgreSQL - Local development
# ==================================================

DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=medical_monitoring_db
DB_USER=medical_app
DB_PASSWORD=your_database_password


# ==================================================
# PostgreSQL - Production
# ==================================================

# Production providers such as Neon supply one connection string.
#
# Example:
# DATABASE_URL=postgresql://username:password@hostname/database?sslmode=require
#
# Leave it empty during local development if the project
# is using the DB_HOST, DB_PORT, DB_NAME, DB_USER and
# DB_PASSWORD variables above.

DATABASE_URL=


# ==================================================
# Authentication
# ==================================================

# JWT_SECRET must contain at least 64 characters.
JWT_SECRET=replace_with_a_long_random_secret_of_at_least_64_characters

JWT_EXPIRES_IN=30m
JWT_REMEMBER_EXPIRES_IN=8h

JWT_COOKIE_NAME=medical_access_token

JWT_ISSUER=medical-monitoring-backend
JWT_AUDIENCE=medical-monitoring-frontend


# Local development:
# JWT_COOKIE_SAME_SITE=lax
#
# Production when frontend and backend use different domains:
# JWT_COOKIE_SAME_SITE=none

JWT_COOKIE_SAME_SITE=lax


# ==================================================
# Dispatch recommendation rules
# ==================================================

# Maximum allowed age of an ambulance location.
DISPATCH_MAX_LOCATION_AGE_SECONDS=120

# Maximum distance between an emergency and ambulance.
DISPATCH_MAX_DISTANCE_METERS=300000

# Time before a recommendation expires.
DISPATCH_RECOMMENDATION_TTL_SECONDS=300